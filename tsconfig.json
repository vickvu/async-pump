{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "types": ["node", "mocha", "chai"],
        "strict": true,
        "declaration": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src", "test"]
}
